<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
>

    <!-- Top bar: search + more icons at top right -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="end|center_vertical">

        <ImageView
            android:id="@+id/btnSearchId"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_search"
            android:padding="12dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Search ID" />

        <ImageView
            android:id="@+id/btnMore"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_more"
            android:padding="12dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="More options" />

    </LinearLayout>

    <!-- Middle area: search result + number input centered in remaining space -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Search result at top of this area -->
        <ScrollView
            android:id="@+id/scrollResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_above="@id/contactList"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:id="@+id/tvSearchResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:padding="4dp"
                android:lineSpacingMultiplier="1.4"
                android:textColor="?android:attr/textColorPrimary"
                android:visibility="gone" />

        </ScrollView>

        <!-- Contact matches list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/contactList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_above="@id/numberRow"
            android:layout_alignParentBottom="false"
            android:visibility="gone" />

        <!-- Number row pinned to bottom, just above keypad -->
        <RelativeLayout
            android:id="@+id/numberRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true">

            <EditText
                android:id="@+id/tvNumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="32sp"
                android:gravity="center"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:paddingStart="56dp"
                android:paddingEnd="56dp"
                android:inputType="none"
                android:textIsSelectable="true"
                android:textCursorDrawable="@drawable/cursor_green"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:background="@null"
                android:textColor="?android:attr/textColorPrimary"
                android:cursorVisible="true" />

            <TextView
                android:id="@+id/btnBackspace"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="8dp"
                android:text="⌫"
                android:textSize="26sp"
                android:padding="12dp"
                android:textColor="?android:attr/textColorPrimary"
                android:clickable="true"
                android:focusable="true" />

        </RelativeLayout>

    </RelativeLayout>

    <!-- Keypad: each cell is a FrameLayout inflated in code -->
    <GridLayout
        android:id="@+id/keypadGrid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:rowCount="4">

        <FrameLayout android:id="@+id/key1" android:layout_width="0dp" android:layout_height="88dp" android:layout_columnWeight="1" android:clickable="true" android:focusable="true" android:background="@drawable/bg_key_ripple" />
        <FrameLayout android:id="@+id/key2" android:layout_width="0dp" android:layout_height="88dp" android:layout_columnWeight="1" android:clickable="true" android:focusable="true" android:background="@drawable/bg_key_ripple" />
        <FrameLayout android:id="@+id/key3" android:layout_width="0dp" android:layout_height="88dp" android:layout_columnWeight="1" android:clickable="true" android:focusable="true" android:background="@drawable/bg_key_ripple" />
        <FrameLayout android:id="@+id/key4" android:layout_width="0dp" android:layout_height="88dp" android:layout_columnWeight="1" android:clickable="true" android:focusable="true" android:background="@drawable/bg_key_ripple" />
        <FrameLayout android:id="@+id/key5" android:layout_width="0dp" android:layout_height="88dp" android:layout_columnWeight="1" android:clickable="true" android:focusable="true" android:background="@drawable/bg_key_ripple" />
        <FrameLayout android:id="@+id/key6" android:layout_width="0dp" android:layout_height="88dp" android:layout_columnWeight="1" android:clickable="true" android:focusable="true" android:background="@drawable/bg_key_ripple" />
        <FrameLayout android:id="@+id/key7" android:layout_width="0dp" android:layout_height="88dp" android:layout_columnWeight="1" android:clickable="true" android:focusable="true" android:background="@drawable/bg_key_ripple" />
        <FrameLayout android:id="@+id/key8" android:layout_width="0dp" android:layout_height="88dp" android:layout_columnWeight="1" android:clickable="true" android:focusable="true" android:background="@drawable/bg_key_ripple" />
        <FrameLayout android:id="@+id/key9" android:layout_width="0dp" android:layout_height="88dp" android:layout_columnWeight="1" android:clickable="true" android:focusable="true" android:background="@drawable/bg_key_ripple" />
        <FrameLayout android:id="@+id/keyStar" android:layout_width="0dp" android:layout_height="88dp" android:layout_columnWeight="1" android:clickable="true" android:focusable="true" android:background="@drawable/bg_key_ripple" />
        <FrameLayout android:id="@+id/key0" android:layout_width="0dp" android:layout_height="88dp" android:layout_columnWeight="1" android:clickable="true" android:focusable="true" android:background="@drawable/bg_key_ripple" />
        <FrameLayout android:id="@+id/keyHash" android:layout_width="0dp" android:layout_height="88dp" android:layout_columnWeight="1" android:clickable="true" android:focusable="true" android:background="@drawable/bg_key_ripple" />

    </GridLayout>

    <!-- Bottom: Recents | Call | Contacts -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="96dp">

        <!-- Recents (left) -->
        <LinearLayout
            android:id="@+id/btnRecents"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="32dp"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackgroundBorderless">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_recents"
                android:contentDescription="Recents" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recents"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                android:textColor="?android:attr/textColorSecondary" />

        </LinearLayout>

        <!-- Call button (center) -->
        <ImageView
            android:id="@+id/btnCall"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_centerInParent="true"
            android:background="@drawable/bg_call_button"
            android:src="@drawable/ic_call"
            android:padding="14dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Call" />

        <!-- Contacts (right) -->
        <LinearLayout
            android:id="@+id/btnContacts"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="32dp"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackgroundBorderless">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_contacts"
                android:contentDescription="Contacts" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contacts"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                android:textColor="?android:attr/textColorSecondary" />

        </LinearLayout>

    </RelativeLayout>

</LinearLayout>
